// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id            Int            @id @default(autoincrement())
  title         String
  slug          String         @unique
  description   String
  content       String?
  icon          String?
  heroImage     String?
  caseImages    String?
  order         Int            @default(0)
  published     Boolean        @default(true)
  metaTitle     String?
  metaDesc      String?
  metaKeywords  String?
  ogImage       String?
  faqItems      String?
  galleryImages GalleryImage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model BeforeAfter {
  id          Int      @id @default(autoincrement())
  title       String
  treatment   String
  beforeImage String   // repurposed as the single combined image
  afterImage  String?  // kept for backward compat, no longer required
  description String?
  published   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  metaTitle    String?
  metaDesc    String?
  metaKeywords String?
  ogImage     String?
  faqItems    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id        Int        @id @default(autoincrement())
  label     String
  href      String
  position  String     @default("left")   // "left" | "right"
  order     Int        @default(0)
  parentId  Int?
  parent    MenuItem?  @relation("SubMenuItems", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("SubMenuItems")
  enabled   Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  description String?
  subcategory String?
  serviceId   Int
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  published   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServicePrice {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       String
  priceNote   String?
  category    String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaFolder {
  id        Int           @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    MediaFolder?  @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("SubFolders")
  files     MediaFile[]
  createdAt DateTime      @default(now())
}

model MediaFile {
  id        Int          @id @default(autoincrement())
  url       String       @unique
  name      String
  size      Int
  mimeType  String
  folderId  Int?
  folder    MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())
}
